EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/v1
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_RAZORPAY_KEY_ID=

# Firebase phone auth (Google sends the SMS — no DLT/GST needed).
# From Firebase console → Project settings → your Web app config.
# Leave empty to fall back to the dev OTP flow (code 123456).
# NOTE: phone auth needs an EAS dev build (reCAPTCHA), not Expo Go.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
