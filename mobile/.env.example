EXPO_PUBLIC_API_BASE_URL=https://thugil-api-production.up.railway.app/v1/
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_RAZORPAY_KEY_ID=

# Firebase phone auth (native @react-native-firebase/auth — Google sends the SMS,
# no DLT/GST needed). Set to true to use real Firebase OTP; leave false/unset for
# the dev OTP flow (code 123456) on simulators.
# Requires google-services.json (Android) + GoogleService-Info.plist (iOS) at the
# mobile/ root, and a fresh EAS build (does NOT work in Expo Go).
EXPO_PUBLIC_USE_FIREBASE_AUTH=false
# Optional: override the Firebase config file paths (e.g. EAS file secrets)
# GOOGLE_SERVICES_JSON=./google-services.json
# GOOGLE_SERVICES_PLIST=./GoogleService-Info.plist
