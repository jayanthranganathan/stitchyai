# --- App ---
APP_ENV=development
APP_NAME=thugil-api
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+psycopg://thugil:thugil@localhost:5432/thugil

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
JWT_SECRET=change-me-in-production
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30

# --- OTP (MSG91) ---
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=THUGIL

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Firebase Cloud Messaging ---
FCM_SERVER_KEY=

# --- Google Maps (server-side key, restricted) ---
GOOGLE_MAPS_API_KEY=

# --- S3 / Object storage ---
S3_BUCKET=thugil-media-dev
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
