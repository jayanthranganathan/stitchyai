# ── AI Worker — Local GPU Server Environment ─────────────────────────────────
# Copy this to .env on your local GPU machine and fill in the values.

# App
APP_ENV=production
LOG_LEVEL=INFO

# Redis — running locally on this same machine (via docker-compose.local.yml)
REDIS_URL=redis://redis:6379/0

# Object storage — use IONOS Object Storage (S3-compatible)
# Get your key pair from: cloud.ionos.com → Object Storage → Access Keys
S3_BUCKET=thugil-production
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-ionos-access-key-id
AWS_SECRET_ACCESS_KEY=your-ionos-secret-key
S3_ENDPOINT_URL=https://s3-eu-central-1.ionoscloud.com
S3_DEV_MODE=false
LOCAL_STORAGE_DIR=/tmp/thugil-dev

# CDN — leave empty to use signed IONOS URLs, or set your CDN domain
CLOUDFRONT_DOMAIN=

# Main API — your IONOS server's public IP or domain
# The AI worker calls this to update job status after generation completes
MAIN_API_URL=https://api.yourdomain.com/v1
AI_SERVICE_API_KEY=change-me-strong-shared-secret   # must match backend .env

# HuggingFace token — required to download FLUX.1-dev and Qwen (gated models)
# Get free at: huggingface.co → Settings → Access Tokens → New token (read)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model storage — maps to /opt/stitchy/models on your machine (see docker-compose.local.yml)
MODEL_CACHE_DIR=/workspace/models

# Inference parameters
NUM_INFERENCE_STEPS=28
GUIDANCE_SCALE=3.5
NUM_DESIGNS=4
OUTPUT_WIDTH=768
OUTPUT_HEIGHT=1024

# GPU memory optimisation
# If your GPU has exactly 24 GB VRAM (RTX 3090 / 4090):
ENABLE_MODEL_CPU_OFFLOAD=true    # offloads layers to RAM when VRAM is full
QWEN_LOAD_IN_4BIT=true           # keeps Qwen at ~6 GB instead of 14 GB

# If your GPU has 48 GB+ VRAM (A6000, A100 40G):
# ENABLE_MODEL_CPU_OFFLOAD=false
# QWEN_LOAD_IN_4BIT=true

# Celery — 1 job at a time per GPU (don't change this)
CELERY_CONCURRENCY=1

# Flower monitoring dashboard password
FLOWER_PASSWORD=change-me-flower-password
