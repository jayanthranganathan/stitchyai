# ── AI Service Environment Variables ─────────────────────────────────────────
# Copy this to .env and fill in the values

# App
APP_ENV=production
LOG_LEVEL=INFO

# Redis (shared with main API)
REDIS_URL=redis://redis:6379/0

# Object storage — works with AWS S3 or any S3-compatible provider
# AWS S3 example:
#   S3_ENDPOINT_URL=         (leave empty)
#   S3_REGION=ap-south-1
#
# IONOS Object Storage example:
#   S3_ENDPOINT_URL=https://s3-eu-central-1.ionoscloud.com
#   S3_REGION=eu-central-1
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY = IONOS key pair from cloud.ionos.com
S3_BUCKET=thugil-production
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
CLOUDFRONT_DOMAIN=cdn.thugil.in
# Local development: set S3_DEV_MODE=true to skip real S3 (reads/writes /tmp/thugil-dev)
S3_DEV_MODE=false
LOCAL_STORAGE_DIR=/tmp/thugil-dev

# Main API (internal docker network)
MAIN_API_URL=http://api:8000/v1
AI_SERVICE_API_KEY=change-me-strong-shared-secret

# HuggingFace (required for FLUX.1-dev gated model)
HF_TOKEN=hf_your_token_here

# Model storage
MODEL_CACHE_DIR=/workspace/models

# Inference parameters (tune for your GPU)
NUM_INFERENCE_STEPS=28
GUIDANCE_SCALE=3.5
NUM_DESIGNS=4
OUTPUT_WIDTH=768
OUTPUT_HEIGHT=1024
ENABLE_MODEL_CPU_OFFLOAD=false    # set true for < 24 GB VRAM
QWEN_LOAD_IN_4BIT=true           # set false for higher quality on 80 GB VRAM

# Celery
CELERY_CONCURRENCY=1             # 1 per GPU; scale via RunPod replicas

# Flower monitoring
FLOWER_PASSWORD=change-me
